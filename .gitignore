# Environment and secrets
.env
.env.local
*.pem
*.key

# Claude Code local machine settings (user-specific permission allowlist, not portable)
.claude/settings.local.json

# Raw data files (2+ GB, too large for git)
# The data dictionary and schema YAML document what's in these files.
# Re-download from NCES/CRDC/OSPI portals if needed.
WA-raw/

# Raw MongoDB exports
data/schools_pipeline.json
data/*export*.json

# Pipeline checkpoint files (regenerated on each run; can be huge for full-batch runs)
data/*checkpoint*.jsonl
data/*checkpoint*.json

# Extracted data intermediates (regenerated by pipeline)
data/ccd_wa_directory.csv
data/ccd_wa_membership.csv
data/crdc_wa/

# Enrichment logs and other runtime logs (generated at runtime)
logs/

# Phase 4.5 test result outputs (per-school JSONs, raw API responses, generated reports)
# The runner scripts (.py) live in the same directories and ARE tracked.
phases/phase-4.5/test_results/raw_responses/
phases/phase-4.5/test_results/**/*.json
phases/phase-4.5/test_results/**/test_run_*.md
phases/phase-4.5/test_results/**/report_*.md
phases/phase-4.5/test_results/**/evaluation.md

# Phase 4 generated reports (pilot batch outputs; the planning/exit docs ARE tracked)
phases/phase-4/pilot_report.md

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.Python
*.egg-info/
.pytest_cache/

# Node (defensive — not currently used, but harmless if added later)
node_modules/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
